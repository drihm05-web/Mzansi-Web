{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "context": { "type": "string" },
        "notes": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "UserStat": {
      "title": "UserStat",
      "description": "User statistics for the dashboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "mitigations": { "type": "number" },
        "uptime": { "type": "number" },
        "requests": { "type": "number" }
      },
      "required": ["id", "userId", "date"]
    },
    "Quote": {
      "title": "Quote",
      "description": "Marketing quotes for clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "requirements": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "sent", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "planName", "amount"]
    },
    "EmailLog": {
      "title": "EmailLog",
      "description": "Log of sent emails",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "failed"] }
      },
      "required": ["id", "to", "subject", "content"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Website building plans",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "targetAudience": { "type": "string" },
        "demoUrl": { "type": "string" }
      },
      "required": ["id", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Client orders for website plans",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "cancelled"] },
        "designBrief": { "type": "string" },
        "amount": { "type": "number" },
        "discountCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "siteUrl": { "type": "string" },
        "adminUrl": { "type": "string" },
        "isCustom": { "type": "boolean" },
        "customRequirements": { "type": "string" },
        "budget": { "type": "number" }
      },
      "required": ["id", "clientId", "planId", "status"]
    },
    "Demo": {
      "title": "Demo",
      "description": "Demo sites to showcase work",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Admin announcements for all users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content"]
    },
    "DiscountCode": {
      "title": "DiscountCode",
      "description": "Promotional discount codes",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "percentage": { "type": "number" },
        "active": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "percentage", "active"]
    },
    "PaymentSettings": {
      "title": "PaymentSettings",
      "description": "EFT and payment instructions settings",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountHolder": { "type": "string" },
        "branchCode": { "type": "string" },
        "instructions": { "type": "string" }
      },
      "required": ["bankName", "accountNumber", "accountHolder"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "PaymentSettings",
      "description": "Global app settings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/userStats/{statId}": {
      "schema": "UserStat",
      "description": "User statistics for dashboard"
    },
    "/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "Marketing quotes"
    },
    "/emailLogs/{logId}": {
      "schema": "EmailLog",
      "description": "Sent email logs"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Available website plans"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global announcements"
    },
    "/discountCodes/{code}": {
      "schema": "DiscountCode",
      "description": "Discount codes"
    },
    "/demos/{demoId}": {
      "schema": "Demo",
      "description": "Demo sites"
    }
  }
}
